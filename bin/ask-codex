#!/usr/bin/env bash
# ask-codex "prompt": consult OpenAI Codex headlessly (Codex CLI).
# Pipe extra context via stdin:  cat file.md | ask-codex "review this"
# Sandbox is read-only by default; override with ASK_CODEX_SANDBOX=workspace-write.
set -euo pipefail

BRIDGE="${AI_BRIDGE_LOG:-$HOME/ai-bridge/log}"
mkdir -p "$BRIDGE"

if [[ $# -lt 1 ]]; then
  echo 'Usage: ask-codex "prompt" [< context.md]' >&2
  exit 1
fi

PROMPT="$*"
TS="$(date +%Y%m%d-%H%M%S)"
OUT="$BRIDGE/$TS-codex.md"
LASTMSG="$(mktemp)"
TRANSCRIPT="$(mktemp)"
trap 'rm -f "$LASTMSG" "$TRANSCRIPT"' EXIT

if codex exec --skip-git-repo-check \
    --sandbox "${ASK_CODEX_SANDBOX:-read-only}" \
    -o "$LASTMSG" "$PROMPT" > "$TRANSCRIPT" 2>&1; then
  {
    printf '# codex %s\n\n## prompt\n%s\n\n## reply\n' "$TS" "$PROMPT"
    cat "$LASTMSG"
  } > "$OUT"
  cat "$LASTMSG"
else
  echo "codex exec failed; transcript follows:" >&2
  cat "$TRANSCRIPT" >&2
  exit 1
fi
