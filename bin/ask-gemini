#!/usr/bin/env bash
# ask-gemini "prompt": consult Google Gemini headlessly (Gemini CLI).
# Pipe extra context via stdin:  cat file.md | ask-gemini "summarize this"
set -euo pipefail

BRIDGE="${AI_BRIDGE_LOG:-$HOME/ai-bridge/log}"
mkdir -p "$BRIDGE"

if [[ $# -lt 1 ]]; then
  echo 'Usage: ask-gemini "prompt" [< context.md]' >&2
  exit 1
fi

PROMPT="$*"
TS="$(date +%Y%m%d-%H%M%S)"
OUT="$BRIDGE/$TS-gemini.md"

printf '# gemini %s\n\n## prompt\n%s\n\n## reply\n' "$TS" "$PROMPT" > "$OUT"
gemini -p "$PROMPT" | tee -a "$OUT"
